# Evolution API Configuration Example
# Copie como .env e preencha os valores

RABBITMQ_ENABLED=false
DB_CONNECTION=sqlite
DB_SAVE_DATA_INSTANCE=true
DB_SAVE_DATA_NEW_MESSAGE=true
DB_URL=file:./evolution.db

LOG_LEVEL=warn
API_KEY=gerada_durante_setup
API_URL=http://localhost:8080

JWT_SECRET=gerada_durante_setup

LANGUAGE=pt
